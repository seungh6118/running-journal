PORT=3000
APP_BASE_URL=http://localhost:3000

# Local default SQLite path. In cloud, set e.g. /data/journal.db
DB_PATH=./journal.db
DEFAULT_SYNC_DAYS=30

# Strava API app settings
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_VERIFY_TOKEN=replace-with-random-string
STRAVA_SCOPES=read,activity:read_all
